---
import BaseLayout from '../layouts/BaseLayout.astro';

const subjects = [
  { id: 'sejarah',   name: 'Sejarah',   desc: 'Peradaban, peristiwa & tokoh.' },
  { id: 'biologi',   name: 'Biologi',   desc: 'Makhluk hidup & ekosistem.' },
  { id: 'ekonomi',   name: 'Ekonomi',   desc: 'Pasar, uang & kebijakan.' },
  { id: 'ppkn',      name: 'PPKn',      desc: 'Pancasila & kewarganegaraan.' },
  { id: 'geografi',  name: 'Geografi',  desc: 'Bumi, ruang & lingkungan.' },
  { id: 'sosiologi', name: 'Sosiologi', desc: 'Masyarakat & interaksi sosial.' },
];

const semesters = [2, 3, 4, 5, 6, 7];
const defaultSem = '2';

// availability[semester][subjectId] = { href, meta }
const availability: Record<string, Record<string, { href: string; meta: string }>> = {
  '2': {
    biologi: { href: '/biologi', meta: 'Bank soal · Flashcards' },
  },
};
---

<BaseLayout title="Rayadien Edu — Kurikulum SMA">
  <div class="hub">
    <div class="hub-inner">
      <header class="hub-head">
        <span class="eyebrow">Kurikulum SMA</span>
        <h1>Rayadien <span>Edu</span></h1>
        <p class="lede">Pilih semester, lalu mata pelajaran. Materi tersusun rapi per jenjang.</p>
      </header>

      <nav class="sem-tabs" id="sem-tabs" aria-label="Pilih semester">
        {semesters.map(s => (
          <button
            class="sem-tab"
            data-sem={String(s)}
            aria-pressed={String(s) === defaultSem ? 'true' : 'false'}
          >
            <span class="sem-k">Sem</span>
            <span class="sem-n">{s}</span>
          </button>
        ))}
      </nav>

      <div class="subject-grid" id="subject-grid">
        {subjects.map((sub, i) => {
          const avail = availability[defaultSem]?.[sub.id];
          const num = String(i + 1).padStart(2, '0');
          return avail ? (
            <a class="subject-card" href={avail.href} data-subject={sub.id}>
              <span class="sc-num">{num}</span>
              <h2>{sub.name}</h2>
              <p class="sc-desc">{sub.desc}</p>
              <span class="sc-meta">{avail.meta}</span>
              <span class="sc-arrow" aria-hidden="true">→</span>
            </a>
          ) : (
            <div class="subject-card is-locked" data-subject={sub.id} aria-disabled="true">
              <span class="sc-num">{num}</span>
              <h2>{sub.name}</h2>
              <p class="sc-desc">{sub.desc}</p>
              <span class="sc-meta">Segera hadir</span>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <script
    is:inline
    id="hub-data"
    type="application/json"
    set:html={JSON.stringify({ subjects, availability, defaultSem })}
  />

  <script>
    import '../scripts/hub.ts';
  </script>
</BaseLayout>

<style is:global>
  .hub {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    background:
      radial-gradient(900px 520px at 82% -12%, #f4f3ef 0%, transparent 60%),
      linear-gradient(180deg, #eceae4 0%, #e4e2da 100%);
    color: #1a1a1a;
    font-family: 'Public Sans', system-ui, sans-serif;
  }

  .hub-inner {
    width: 100%;
    max-width: 920px;
  }

  /* ── Header ── */
  .hub-head {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #e0533d;
    margin-bottom: 0.85rem;
  }

  .hub-head h1 {
    font-family: 'Spectral', serif;
    font-size: clamp(2.8rem, 7vw, 4.6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    color: #1a1a1a;
  }

  .hub-head h1 span {
    font-style: italic;
    font-weight: 500;
    color: #e0533d;
  }

  .lede {
    margin: 1rem 0 0;
    font-size: 1.05rem;
    color: #6a6a64;
    max-width: 44ch;
  }

  /* ── Semester Tabs ── */
  .sem-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .sem-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    min-width: 64px;
    padding: 0.6rem 0.9rem;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    color: #1a1a1a;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Public Sans', sans-serif;
  }

  .sem-tab .sem-k {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8a8a85;
  }

  .sem-tab .sem-n {
    font-family: 'Spectral', serif;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
  }

  .sem-tab:hover {
    border-color: #e0533d;
    transform: translateY(-2px);
  }

  .sem-tab[aria-pressed='true'] {
    background: #e0533d;
    border-color: #e0533d;
    color: #ffffff;
  }

  .sem-tab[aria-pressed='true'] .sem-k {
    color: rgba(255, 255, 255, 0.75);
  }

  /* ── Subject Grid ── */
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .subject-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.4rem 1.5rem 1.5rem;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.22s cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 0.22s, border-color 0.22s;
  }

  .subject-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: #e0533d;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.22s ease;
  }

  a.subject-card:hover {
    transform: translateY(-4px);
    border-color: rgba(224, 83, 61, 0.4);
    box-shadow: 0 18px 40px -18px rgba(40, 38, 34, 0.35);
  }

  a.subject-card:hover::before {
    transform: scaleY(1);
  }

  .sc-num {
    font-family: 'Spectral', serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #c9c7bf;
    letter-spacing: 0.05em;
  }

  .subject-card h2 {
    font-family: 'Spectral', serif;
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0.5rem 0 0;
    color: #1a1a1a;
  }

  .sc-desc {
    margin: 0.35rem 0 1.1rem;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #8a8a85;
    flex: 1;
  }

  .sc-meta {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #e0533d;
  }

  .sc-arrow {
    position: absolute;
    right: 1.3rem;
    bottom: 1.4rem;
    font-size: 1.1rem;
    color: #e0533d;
    transform: translateX(-4px);
    opacity: 0;
    transition: all 0.22s ease;
  }

  a.subject-card:hover .sc-arrow {
    transform: translateX(0);
    opacity: 1;
  }

  /* ── Locked ── */
  .subject-card.is-locked {
    background: rgba(255, 255, 255, 0.45);
    border-style: dashed;
    cursor: not-allowed;
  }

  .subject-card.is-locked h2 {
    color: #9a9a93;
  }

  .subject-card.is-locked .sc-meta {
    color: #b0b0a8;
  }

  /* ── Reveal ── */
  .subject-card {
    opacity: 0;
    transform: translateY(16px);
    animation: hubRise 0.5s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }

  .subject-card:nth-child(1) { animation-delay: 0.04s; }
  .subject-card:nth-child(2) { animation-delay: 0.09s; }
  .subject-card:nth-child(3) { animation-delay: 0.14s; }
  .subject-card:nth-child(4) { animation-delay: 0.19s; }
  .subject-card:nth-child(5) { animation-delay: 0.24s; }
  .subject-card:nth-child(6) { animation-delay: 0.29s; }

  @keyframes hubRise {
    to { opacity: 1; transform: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .subject-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 460px) {
    .subject-grid { grid-template-columns: 1fr; }
    .hub { padding: 2rem 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .subject-card { animation: none; opacity: 1; transform: none; }
    .sem-tab:hover, a.subject-card:hover { transform: none; }
  }
</style>
