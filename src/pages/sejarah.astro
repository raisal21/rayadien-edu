---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressBar from '../components/ProgressBar.astro';
import TopBar from '../components/TopBar.astro';
import Hero from '../components/Hero.astro';
import EntryCard from '../components/EntryCard.astro';
import BagianHeader from '../components/BagianHeader.astro';
import TopicDivider from '../components/TopicDivider.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import Lightbox from '../components/Lightbox.astro';

const entries = (await getCollection('entries')).filter(e => e.data.subject === 'sejarah');
const byBagian = (b: string) =>
  entries.filter(e => e.data.bagian === b).sort((a, c) => a.data.nomor - c.data.nomor);

// Group bagian A by topic, preserving the order topics first appear.
const aEntries = byBagian('A');
const aGroups: { topic: string; items: typeof aEntries }[] = [];
for (const e of aEntries) {
  let g = aGroups.find(x => x.topic === e.data.topic);
  if (!g) { g = { topic: e.data.topic, items: [] }; aGroups.push(g); }
  g.items.push(e);
}

const bEntries = byBagian('B');
const cEntries = byBagian('C');

const TOPIC_LABEL: Record<string, string> = {
  'hindu-buddha': 'Topik 1 · Hindu-Buddha',
  islam: 'Topik 2 · Islam',
};
const rangeOf = (items: typeof aEntries) =>
  `No. ${items[0]?.data.nomor}–${items[items.length - 1]?.data.nomor}`;
---

<BaseLayout title="Sejarah Kelas X — Hindu-Buddha & Islam Nusantara">
  <ProgressBar />
  <TopBar
    subject="sejarah"
    brand="Sejarah X"
    brandSub="Kisi-Kisi ASAT"
    filters={[
      { value: 'all', label: 'Semua' },
      { value: 'hindu-buddha', label: 'Hindu-Buddha' },
      { value: 'islam', label: 'Islam' },
    ]}
  />
  <Hero
    eyebrow="Materi Belajar &middot; ASAT Genap 2025/2026"
    titleMain="Sejarah"
    titleEm="Kelas X"
    titleSub="Hindu-Buddha & Islam Nusantara"
    lede="Catatan ringkas untuk asesmen akhir tahun &mdash; disusun mengikuti <b>kisi-kisi</b>: teori masuk, saluran penyebaran, serta kerajaan Hindu-Buddha & Islam di Nusantara."
    src="Sumber: rangkuman materi sejarah Indonesia &mdash; selaraskan dengan catatan & buku pegangan kelas."
    legend={[
      { cls: 'n', label: 'Hindu-Buddha' },
      { cls: 'n', label: 'Islam' },
      { cls: 'n', label: '40 soal &middot; A 25 &middot; B 10 &middot; C 5' },
    ]}
    flashHref={false}
    howto="<b>Cara pakai:</b> baca <em>indikator</em> &#x2192; pahami <em>inti materi</em> &#x2192; buka <em>trik jawab</em>. Pakai tombol topik di atas untuk fokus, atau ketik di kotak <em>cari</em>."
  />

  <main class="wrap reading" id="main">
    <BagianHeader bagian="A" title="Pilihan Ganda" count={aEntries.length} />
    {aGroups.map(g => (
      <>
        <TopicDivider topic={g.topic} label={TOPIC_LABEL[g.topic] ?? g.topic} range={rangeOf(g.items)} />
        {g.items.map(entry => <EntryCard entry={entry} />)}
      </>
    ))}

    <BagianHeader
      bagian="B"
      title="Pilihan Ganda Kompleks"
      count={bEntries.length}
      note="⚠️ PG Kompleks = <u>jawaban benar bisa lebih dari satu</u>. Centang <strong>semua</strong> yang tepat, jangan berhenti di satu."
    />
    {bEntries.map(entry => <EntryCard entry={entry} />)}

    <BagianHeader
      bagian="C"
      title="Isian Singkat"
      count={cEntries.length}
      note="✍️ Isian singkat = jawab <strong>ringkas & tepat</strong> (istilah/nama/tahun)."
    />
    {cEntries.map(entry => <EntryCard entry={entry} />)}

    <Footer />
  </main>

  <BackToTop />
  <Lightbox />

  <script>
    import '../scripts/interactive.ts';
  </script>
</BaseLayout>
