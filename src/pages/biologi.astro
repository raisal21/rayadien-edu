---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressBar from '../components/ProgressBar.astro';
import TopBar from '../components/TopBar.astro';
import Hero from '../components/Hero.astro';
import EntryCard from '../components/EntryCard.astro';
import BagianHeader from '../components/BagianHeader.astro';
import TopicDivider from '../components/TopicDivider.astro';
import OverviewPlates from '../components/OverviewPlates.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import Lightbox from '../components/Lightbox.astro';

const allEntries = (await getCollection('entries')).filter(e => e.data.subject === 'biologi');

const bagianA = allEntries.filter(e => e.data.bagian === 'A').sort((a, b) => a.data.nomor - b.data.nomor);
const bagianB = allEntries.filter(e => e.data.bagian === 'B').sort((a, b) => a.data.nomor - b.data.nomor);
const bagianC = allEntries.filter(e => e.data.bagian === 'C').sort((a, b) => a.data.nomor - b.data.nomor);

const aJamur = bagianA.filter(e => e.data.topic === 'jamur');
const aEko = bagianA.filter(e => e.data.topic === 'eko');
const bJamur = bagianB.filter(e => e.data.topic === 'jamur');
const bEko = bagianB.filter(e => e.data.topic === 'eko');
const cJamur = bagianC.filter(e => e.data.topic === 'jamur');
const cEko = bagianC.filter(e => e.data.topic === 'eko');
---

<BaseLayout title="Biologi Kelas X — Jamur & Ekosistem">
  <ProgressBar />
  <TopBar />
  <Hero />

  <main class="wrap reading" id="main">
    <BagianHeader bagian="A" title="Pilihan Ganda" count={25} />

    <TopicDivider topic="jamur" label="Topik 1 · Jamur (Fungi)" range={`No. 1–${aJamur.length}`} />

    <OverviewPlates
      topic="jamur"
      title="Jamur"
      subtitle="Dua plat acuan menyeluruh — pelajari dulu sebelum masuk ke soal per nomor."
      plates={[
        {
          src: 'img/jamur-overview-struktur.webp',
          alt: 'Infografik struktur fungi (jamur) dan perannya: tudung, lamela, cincin, stipe, volva, miselium, hifa, dinding sel, septa.',
          cap: 'Struktur tubuh jamur lengkap (tudung, lamela, cincin, tangkai, volva, miselium, hifa) beserta perannya.',
          label: 'Struktur jamur & perannya.',
        },
        {
          src: 'img/jamur-overview-reproduksi.webp',
          alt: 'Infografik reproduksi jamur pada 4 divisi (Zygomycota, Ascomycota, Basidiomycota, Deuteromycota) secara vegetatif dan generatif.',
          cap: 'Reproduksi jamur pada 4 divisi: Zygomycota, Ascomycota, Basidiomycota, Deuteromycota — vegetatif (aseksual) dan generatif (seksual).',
          label: 'Reproduksi 4 divisi jamur.',
        },
      ]}
    />

    {aJamur.map(entry => <EntryCard entry={entry} />)}

    <TopicDivider topic="eko" label="Topik 2 · Ekosistem" range={`No. ${aEko[0]?.data.nomor || 13}–${aEko[aEko.length - 1]?.data.nomor || 25}`} />

    {aEko.map(entry => <EntryCard entry={entry} />)}

    <BagianHeader
      bagian="B"
      title="Pilihan Ganda Kompleks"
      count={5}
      note="⚠️ PG Kompleks = <u>jawaban benar bisa lebih dari satu</u>. Centang <strong>semua</strong> yang tepat, jangan berhenti di satu."
    />

    <TopicDivider topic="jamur" label="Topik 1 · Jamur" range={`No. 1–${bJamur.length}`} />

    {bJamur.map(entry => <EntryCard entry={entry} />)}

    <TopicDivider topic="eko" label="Topik 2 · Ekosistem" range={`No. ${bEko[0]?.data.nomor || 4}–${bEko[bEko.length - 1]?.data.nomor || 5}`} />

    {bEko.map(entry => <EntryCard entry={entry} />)}

    <BagianHeader
      bagian="C"
      title="Isian Singkat"
      count={5}
      note="✍️ Isian singkat = jawab <strong>ringkas & tepat</strong> (istilah/nama/angka). Tulis nama spesies dengan <em>huruf miring</em>."
    />

    <TopicDivider topic="jamur" label="Topik 1 · Jamur" range={`No. 1–${cJamur.length}`} />

    {cJamur.map(entry => <EntryCard entry={entry} />)}

    <TopicDivider topic="eko" label="Topik 2 · Ekosistem" range={`No. ${cEko[0]?.data.nomor || 3}–${cEko[cEko.length - 1]?.data.nomor || 5}`} />

    {cEko.map(entry => <EntryCard entry={entry} />)}

    <Footer />
  </main>

  <BackToTop />
  <Lightbox />

  <script>
    import '../scripts/interactive.ts';
  </script>
</BaseLayout>
