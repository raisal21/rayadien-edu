---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..700&family=Mulish:ital,wght@0,400..800;1,400..600&family=Spectral:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&family=Public+Sans:ital,wght@0,400..800;1,400..600&display=swap" rel="stylesheet">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath d='M12 4C7.6 4 4 6.8 4 10c0 .9.7 1.5 1.6 1.5h12.8c.9 0 1.6-.6 1.6-1.5 0-3.2-3.6-6-8-6z' fill='%23e0533d'/%3E%3Cpath d='M9.6 11.5h4.8l-.5 6.6a1.9 1.9 0 0 1-3.8 0z' fill='%231a1a1a'/%3E%3C/svg%3E">
</head>
<body>
  <slot />
</body>
</html>
