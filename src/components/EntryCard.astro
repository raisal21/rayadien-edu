---
import { render } from 'astro:content';
import { IMAGE_DIMS } from '../lib/imageMeta';

interface Props {
  entry: {
    id: string;
    data: {
      subject: 'biologi' | 'sejarah' | 'ekonomi' | 'geografi' | 'ppkn';
      semester: number;
      topic: string;
      bagian: 'A' | 'B' | 'C';
      type: 'pg' | 'pg-kompleks' | 'isian';
      nomor: number;
      title: string;
      indikator: string;
      image?: string;
      diagram?: string;
      trik?: string;
    };
    body?: string;
  };
}

// Display label per sub-topic. Unknown topics fall back to a title-cased slug.
const TOPIC_LABELS: Record<string, string> = {
  jamur: 'Jamur',
  eko: 'Ekosistem',
  'hindu-buddha': 'Hindu-Buddha',
  islam: 'Islam',
  mikro: 'Mikroekonomi',
  pembayaran: 'Sistem Pembayaran',
  lembaga: 'Lembaga Keuangan',
  hidrosfer: 'Hidrosfer',
  'peta-pj': 'Peta & PJ',
  'warga-negara': 'Warga Negara',
  hankam: 'Pertahanan & Keamanan',
  'hubungan-internasional': 'Hubungan Internasional',
  pancasila: 'Nilai Pancasila',
};

const { entry } = Astro.props;
const { data } = entry;
const qnum = `${data.bagian}${data.nomor}`;
const hasImage = !!data.image;
const topicLabel =
  TOPIC_LABELS[data.topic] ??
  data.topic.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());

const { Content } = await render(entry);
const dims = data.image ? IMAGE_DIMS[data.image] : undefined;
---

<article
  class:list={['entry', 'reveal', { lonely: !hasImage }]}
  data-topic={data.topic}
  id={qnum}
>
  <header class="entry-head">
    <span class="qnum">{qnum}</span>
    <h3>{data.title}</h3>
    <span class="badge">{topicLabel}</span>
  </header>

  <blockquote class="indikator" set:html={data.indikator} />

  {hasImage && (
    <figure class="plate">
      <button class="plate-frame">
        <img src={`/${data.image}`} loading="lazy" alt={data.title} width={dims?.width} height={dims?.height}>
      </button>
      <figcaption>
        <span class="cap"><b>Gambar</b>{data.title}.</span>
        <span class="zoom">&#x2295; perbesar</span>
      </figcaption>
    </figure>
  )}

  <Content />

  {data.trik && (
    <details class="trik">
      <summary>
        <span class="ico">&#x1F4A1;</span>Trik jawab<span class="chev">&#x25B6;</span>
      </summary>
      <div set:html={data.trik} />
    </details>
  )}
</article>
