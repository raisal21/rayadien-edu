---
interface Chip {
  cls?: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  titleMain?: string;
  titleEm?: string;
  titleSub?: string;
  lede?: string;
  src?: string;
  legend?: Chip[];
  flashHref?: string | false;
  howto?: string;
}

const {
  eyebrow = 'Materi Belajar &middot; ASAS Genap 2025/2026',
  titleMain = 'Biologi',
  titleEm = 'Kelas X',
  titleSub = 'Jamur & Ekosistem',
  lede = 'Catatan lengkap buat asesmen akhir semester &mdash; disusun <b>pas sama kisi-kisi</b>, dengan gambar untuk tiap materi yang diujikan.',
  src = 'Sumber: materi <em>Fungi</em> &amp; <em>Ekosistem</em> oleh Rahma Yeni, S.Pd &mdash; tanpa tambahan dari luar.',
  legend = [
    { cls: 'j', label: 'Jamur (Fungi)' },
    { cls: 'e', label: 'Ekosistem' },
    { cls: 'n', label: '35 soal &middot; A 25 &middot; B 5 &middot; C 5' },
  ],
  flashHref = '/flashcards',
  howto = '<b>Cara pakai:</b> baca <em>indikator</em> &#x2192; pahami <em>inti materi</em> &#x2192; amati <em>gambar</em> (klik untuk perbesar &amp; geser) &#x2192; buka <em>trik jawab</em>. Pakai tombol topik di atas untuk fokus ke satu topik.',
} = Astro.props;
---

<header class="hero">
  <div class="wrap">
    <p class="eyebrow" set:html={eyebrow} />
    <h1>{titleMain} <em>{titleEm}</em><br>{titleSub}</h1>
    <p class="lede" set:html={lede} />
    {src && <p class="src" set:html={src} />}
    {legend.length > 0 && (
      <div class="legend">
        {legend.map(c => (
          <span class:list={['chip', c.cls]}><span class="dot"></span><span set:html={c.label} /></span>
        ))}
      </div>
    )}
    {flashHref && (
      <a href={flashHref} class="flash-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
          <path d="M21 3v5h-5"/>
          <path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>
          <path d="M3 21v-5h5"/>
        </svg>
        <span>Latihan pakai Flashcards</span>
        <span class="fb-arrow" aria-hidden="true">&#x2192;</span>
      </a>
    )}
    {howto && (
      <div class="howto">
        <span class="ico">&#x1F343;</span>
        <span set:html={howto} />
      </div>
    )}

    <div class="hero-rule" aria-hidden="true"></div>
  </div>
</header>
