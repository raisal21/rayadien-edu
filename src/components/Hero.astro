---
interface Chip {
  cls?: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  titleMain?: string;
  titleEm?: string;
  titleSub?: string;
  lede?: string;
  src?: string;
  legend?: Chip[];
  flashHref?: string | false;
  howto?: string;
}

const {
  eyebrow = 'Materi Belajar &middot; ASAS Genap 2025/2026',
  titleMain = 'Biologi',
  titleEm = 'Kelas X',
  titleSub = 'Jamur & Ekosistem',
  lede = 'Catatan lengkap untuk asesmen akhir semester &mdash; disusun <b>1:1 mengikuti kisi-kisi</b>, dengan plat gambar untuk tiap materi yang diujikan.',
  src = 'Sumber: materi <em>Fungi</em> &amp; <em>Ekosistem</em> oleh Rahma Yeni, S.Pd &mdash; tanpa tambahan dari luar.',
  legend = [
    { cls: 'j', label: 'Jamur (Fungi)' },
    { cls: 'e', label: 'Ekosistem' },
    { cls: 'n', label: '35 soal &middot; A 25 &middot; B 5 &middot; C 5' },
  ],
  flashHref = '/flashcards',
  howto = '<b>Cara pakai:</b> baca <em>indikator</em> &#x2192; pahami <em>inti materi</em> &#x2192; amati <em>plat gambar</em> (klik untuk perbesar &amp; geser) &#x2192; buka <em>trik jawab</em>. Pakai tombol topik di atas untuk fokus satu topik, atau ketik di kotak <em>cari</em>.',
} = Astro.props;
---

<header class="hero">
  <span class="sprig tr" aria-hidden="true">
    <svg viewBox="0 0 240 240"><defs><path id="lf" d="M0 0C10 -6 10 -20 0 -28C-10 -20 -10 -6 0 0Z"/></defs>
      <path d="M20 222C80 184 130 152 150 82C158 54 170 38 198 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"/>
      <g fill="currentColor"><use href="#lf" transform="translate(126 152) rotate(-42)"/><use href="#lf" transform="translate(137 128) rotate(44)"/><use href="#lf" transform="translate(143 106) rotate(-36)"/><use href="#lf" transform="translate(150 84) rotate(38)"/><use href="#lf" transform="translate(160 60) rotate(-30)"/><use href="#lf" transform="translate(174 42) rotate(32)"/><use href="#lf" transform="translate(190 30) rotate(-20)"/><use href="#lf" transform="translate(199 22) rotate(14) scale(.8)"/></g>
    </svg>
  </span>
  <span class="sprig bl" aria-hidden="true">
    <svg viewBox="0 0 240 240"><use href="#lf" x="0" y="0"/>
      <path d="M20 222C80 184 130 152 150 82C158 54 170 38 198 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"/>
      <g fill="currentColor"><use href="#lf" transform="translate(126 152) rotate(-42)"/><use href="#lf" transform="translate(137 128) rotate(44)"/><use href="#lf" transform="translate(143 106) rotate(-36)"/><use href="#lf" transform="translate(150 84) rotate(38)"/><use href="#lf" transform="translate(160 60) rotate(-30)"/><use href="#lf" transform="translate(174 42) rotate(32)"/><use href="#lf" transform="translate(190 30) rotate(-20)"/></g>
    </svg>
  </span>
  <div class="wrap">
    <p class="eyebrow" set:html={eyebrow} />
    <h1>{titleMain} <em>{titleEm}</em><br>{titleSub}</h1>
    <p class="lede" set:html={lede} />
    {src && <p class="src" set:html={src} />}
    {legend.length > 0 && (
      <div class="legend">
        {legend.map(c => (
          <span class:list={['chip', c.cls]}><span class="dot"></span><span set:html={c.label} /></span>
        ))}
      </div>
    )}
    {flashHref && (
      <a href={flashHref} class="flash-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
          <path d="M21 3v5h-5"/>
          <path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>
          <path d="M3 21v-5h5"/>
        </svg>
        <span>Belajar dengan Flashcards</span>
      </a>
    )}
    {howto && (
      <div class="howto">
        <span class="ico">&#x1F343;</span>
        <span set:html={howto} />
      </div>
    )}
  </div>
</header>
