---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  cards: any[];
  decks: string[];
  subject?: string;
  backHref?: string;
  backLabel?: string;
  title?: string;
}

const {
  cards,
  decks,
  subject = 'all',
  backHref = '/',
  backLabel = '← Kembali',
  title = 'Flashcards - Rayadien Edu',
} = Astro.props;
---

<BaseLayout title={title} subject={subject === 'all' ? undefined : subject}>
  <div class="flash-page">
    <div class="flash-layout">
      <aside class="flash-rail">
        <a href={backHref} class="back-link" id="back-link" data-astro-prefetch="viewport">{backLabel}</a>
        <h1>Flash<span>cards</span></h1>
        <p class="subtitle">Belajar dengan kartu interaktif</p>

        <div class="deck-selector">
          <label for="deck">Deck</label>
          <select id="deck">
            <option value="__all__">Semua kartu</option>
            {decks.map(deck => (
              <option value={deck}>{deck}</option>
            ))}
          </select>
        </div>

        <div class="progress-block">
          <div class="progress-count">
            <span id="current">1</span><span class="of">/ <span id="total">0</span></span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
        </div>

        <div class="kbd-hints">
          <span class="kbd-row"><kbd>&larr;</kbd><kbd>&rarr;</kbd> navigasi</span>
          <span class="kbd-row"><kbd>Space</kbd> flip kartu</span>
        </div>
      </aside>

      <main class="flash-main">
        <div class="card-stage" id="card-stage">
          <div class="card-stack" id="card-stack"></div>
        </div>

        <div class="controls">
          <button id="prev-btn" class="nav-btn" disabled aria-label="Kartu sebelumnya">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button id="flip-btn" class="flip-btn" aria-label="Balik kartu">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
            Balik
          </button>
          <button id="next-btn" class="nav-btn" aria-label="Kartu selanjutnya">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </main>
    </div>
  </div>

  <script is:inline id="flashcards-data" type="application/json" set:html={JSON.stringify(cards)} />

  <script>
    import '../scripts/flashcards.ts';
  </script>
</BaseLayout>

<style is:global>
  /* ── Page Shell ── */
  .flash-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    background:
      radial-gradient(900px 500px at 80% -10%, var(--card) 0%, transparent 60%),
      linear-gradient(180deg, var(--paper) 0%, var(--paper-2) 100%);
    color: var(--ink);
    font-family: var(--font-body);
  }

  /* ── Two-column Layout ── */
  .flash-layout {
    display: grid;
    grid-template-columns: minmax(240px, 320px) auto;
    gap: 3.5rem;
    align-items: center;
    width: 100%;
    max-width: 880px;
  }

  /* ── Left Rail ── */
  .flash-rail {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    align-self: stretch;
    justify-content: center;
    padding-right: 1rem;
    border-right: 1px solid rgba(0,0,0,0.08);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    padding: 0.5rem 0.95rem;
    background: var(--paper);
    color: var(--ink);
    border: 1.5px solid var(--ink);
    border-radius: 8px;
    box-shadow: var(--sh-1) var(--ink);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: transform 0.15s, box-shadow 0.15s, color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
    box-shadow: var(--sh-2) var(--accent);
    transform: translate(-1px, -1px);
  }

  .flash-rail h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    font-weight: 800;
    margin: 0;
    color: var(--ink);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .flash-rail h1 span {
    display: block;
    color: var(--accent);
    font-style: italic;
    font-weight: 500;
  }

  .subtitle {
    color: var(--ink-soft);
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
  }

  /* ── Deck Selector ── */
  .deck-selector {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 2.25rem;
    width: 100%;
  }

  .deck-selector label {
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .deck-selector select {
    padding: 0.55rem 0.85rem;
    background: var(--card);
    color: var(--ink);
    border: var(--bw) solid var(--line-2);
    border-radius: 10px;
    font-size: 0.95rem;
    font-family: var(--font-body);
    font-weight: 600;
    cursor: pointer;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
  }

  .deck-selector select:focus {
    border-color: var(--accent);
  }

  /* ── Progress ── */
  .progress-block {
    margin-top: 2rem;
    width: 100%;
  }

  .progress-count {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .progress-count .of {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink-soft);
  }

  .progress-track {
    margin-top: 0.65rem;
    height: 6px;
    border-radius: 99px;
    background: rgba(0,0,0,0.08);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0;
    border-radius: 99px;
    background: var(--accent);
    transition: width 0.4s cubic-bezier(0.2, 0, 0.2, 1);
  }

  /* ── Main Column ── */
  .flash-main {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Card Stage ── */
  .card-stage {
    position: relative;
    width: 380px;
    height: 532px;
    margin: 0 0 1.5rem;
    perspective: 1600px;
  }

  .card-stack {
    position: relative;
    width: 100%;
    height: 100%;
    perspective: 1600px;
  }

  /* ── Card ── */
  .card {
    --pointer-x: 0;
    --pointer-y: 0;
    --flip-shadow: 0.12;
    position: absolute;
    inset: 0;
    perspective: 1600px;
    user-select: none;
    -webkit-user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .card *:not(.card-flip-btn) {
    pointer-events: none;
  }

  .card[data-depth="0"] {
    z-index: 3;
    opacity: 1;
    transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .card[data-depth="0"][data-active="true"]:hover {
    transform:
      scale(1) translateY(0)
      rotateX(calc(var(--pointer-y) * 12deg))
      rotateY(calc(var(--pointer-x) * -12deg));
    transition: transform 0.1s ease-out;
  }

  .card[data-depth="0"]:not(:hover) {
    transform: scale(1) translateY(0);
    transition: transform 0.5s cubic-bezier(0.2, 0, 0.2, 1);
  }

  .card.is-entering,
  .card.is-leaving,
  .card.is-shuffling {
    transition: none !important;
    will-change: transform, opacity;
  }

  .card[data-depth="1"] {
    transform: translateY(-18px) scale(0.96);
    opacity: 0.52;
    z-index: 2;
    pointer-events: none;
  }

  .card[data-depth="2"] {
    transform: translateY(-36px) scale(0.92);
    opacity: 0.24;
    z-index: 1;
    pointer-events: none;
  }

  /* ── Card Flip Button ── */
  .card-flip-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    z-index: 100;
    cursor: pointer;
    border: none;
    background: transparent;
    -webkit-tap-highlight-color: transparent;
  }

  /* ── Card Inner (3D flip container) ── */
  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform: rotateY(0deg);
    transform-style: preserve-3d;
    transform-origin: center center;
    will-change: transform;
  }

  .card.is-flipped .card-inner {
    transform: rotateY(180deg);
  }

  /* ── Card Faces ── */
  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 20px;
    border: 1px solid rgba(0, 0, 0, 0.07);
    box-shadow:
      0 24px 58px rgba(40, 38, 34, var(--flip-shadow)),
      0 4px 14px rgba(40, 38, 34, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-face::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 10%, var(--accent-bg), transparent 32%);
    pointer-events: none;
    z-index: 0;
  }

  .card-front {
    background: linear-gradient(180deg, var(--card) 0%, var(--card-2) 100%);
    transform: translateZ(1px);
  }

  .card-back {
    background: linear-gradient(180deg, var(--paper) 0%, var(--paper-2) 100%);
    transform: rotateY(180deg) translateZ(1px);
  }

  /* ── Spotlight ── */
  .spotlight {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    border-radius: 24px;
    overflow: hidden;
  }

  .spotlight::before {
    content: '';
    position: absolute;
    width: 350%;
    aspect-ratio: 1;
    left: 50%;
    top: 50%;
    background: radial-gradient(
      rgba(255, 255, 255, 0.5) 0 3%,
      transparent 30%
    );
    translate: calc(-50% + var(--pointer-x, 0) * 25%)
               calc(-50% + var(--pointer-y, 0) * 25%);
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: overlay;
  }

  .card:hover .spotlight::before {
    opacity: 1;
  }

  /* ── Card Content ── */
  .card-label {
    padding: 1.25rem 1.5rem 0;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-label .label-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    font-weight: 800;
    flex-shrink: 0;
  }

  .card-front .card-label {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  .card-front .label-icon {
    background: var(--accent-bg);
    color: var(--accent);
    border: 1px solid var(--accent-soft);
    font-size: 0.75rem;
  }

  .card-back .card-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
  }

  .card-back .label-icon {
    background: var(--accent-bg);
    color: var(--accent);
    border: 1px solid var(--accent-soft);
    font-size: 0.65rem;
  }

  .card-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .card-front .card-content {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.42;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .card-back .card-content {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.72;
    font-weight: 400;
  }

  .card-content {
    color: var(--ink);
    text-align: center;
    max-width: 100%;
    overflow-y: auto;
  }

  .card-content strong {
    color: var(--accent);
    font-weight: 700;
  }

  .card-back .card-content strong {
    color: var(--accent-2);
  }

  .card-content em {
    font-style: italic;
    opacity: 0.9;
  }

  .card-content ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    text-align: left;
  }

  .card-content li {
    padding: 0.25rem 0 0.25rem 1.25rem;
    position: relative;
  }

  .card-content li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.85;
  }

  .card-back .card-content li::before {
    background: var(--accent);
  }

  .card-content p {
    margin: 0.4rem 0;
  }

  .card-content p:first-child { margin-top: 0; }
  .card-content p:last-child { margin-bottom: 0; }

  /* ── Back Watermark ── */
  .card-back .card-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    font-size: 8rem;
    font-weight: 800;
    color: var(--ink);
    opacity: 0.04;
    pointer-events: none;
    z-index: 1;
    line-height: 1;
    user-select: none;
  }

  /* ── Card Accent Bars ── */
  .card-front::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 1;
    z-index: 2;
  }

  .card-back::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0.85;
    z-index: 2;
  }

  /* ── Controls ── */
  .controls {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 10px;
    box-shadow: var(--sh-1) var(--ink);
    color: var(--ink);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, color 0.15s;
  }

  .nav-btn:hover:not(:disabled) {
    color: var(--accent);
    box-shadow: var(--sh-2) var(--accent);
    transform: translate(-1px, -1px);
  }

  .nav-btn:disabled {
    opacity: 0.35;
    box-shadow: none;
    cursor: not-allowed;
  }

  .flip-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 48px;
    padding: 0 1.5rem;
    background: var(--accent);
    border: 1.5px solid var(--ink);
    border-radius: 10px;
    box-shadow: var(--sh-1) var(--ink);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .flip-btn:hover {
    box-shadow: var(--sh-2) var(--ink);
    transform: translate(-1px, -1px);
  }

  .flip-btn svg { flex-shrink: 0; }

  /* ── Keyboard Hints ── */
  .kbd-hints {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-soft-2);
    padding: 0.85rem 1rem;
    border: 1.5px dashed var(--ink);
    border-radius: 10px;
    background: var(--accent-bg);
  }

  .kbd-row {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .kbd-hints kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 26px;
    height: 26px;
    padding: 0 7px;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 6px;
    box-shadow: 1.5px 1.5px 0 var(--ink);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--ink);
  }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .flash-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      max-width: 420px;
    }

    .flash-rail {
      align-items: center;
      text-align: center;
      padding-right: 0;
      padding-bottom: 1.5rem;
      border-right: none;
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }

    .flash-rail h1 span { display: inline; }
    .back-link { margin-bottom: 1rem; }
    .deck-selector { align-items: center; max-width: 280px; }
    .progress-block { max-width: 280px; }
    .progress-count { justify-content: center; }
    .kbd-hints { flex-direction: row; gap: 1rem; }
  }

  @media (max-width: 480px) {
    .card-stage {
      width: 300px;
      height: 420px;
    }

    .flash-rail h1 { font-size: 2.2rem; }

    .card-front .card-content { font-size: 1.1rem; }
    .card-back .card-content { font-size: 0.9rem; }
    .card-label { padding: 1rem 1.25rem 0; }
    .card-front .card-label { font-size: 0.7rem; }
    .card-back .card-label { font-size: 0.6rem; }
    .card-body { padding: 1rem 1.25rem; }
    .card-back .card-watermark { font-size: 6rem; }

    .kbd-hints { display: none; }
  }
</style>
