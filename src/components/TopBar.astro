---
interface Filter {
  value: string;
  label: string;
}

interface Props {
  subject?: string;
  brand?: string;
  brandSub?: string;
  filters?: Filter[];
}

const {
  brand = 'Biologi X',
  brandSub = 'Kisi-Kisi ASAT',
  filters = [
    { value: 'all', label: 'Semua' },
    { value: 'jamur', label: 'Jamur' },
    { value: 'eko', label: 'Ekosistem' },
  ],
} = Astro.props;
---

<div class="topbar" id="topbar">
  <div class="wrap">
    <a href="/" class="home-btn" aria-label="Kembali ke beranda">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/></svg>
      <span class="ht">Beranda</span>
    </a>
    <span class="brand">
      <svg class="brand-logo" viewBox="0 0 24 24" aria-hidden="true">
        <path class="logo-star" d="M12 2.1L12.85 4.15L14.9 5L12.85 5.85L12 7.9L11.15 5.85L9.1 5L11.15 4.15Z"/>
        <path d="M11.3 9.4C8.8 7.9 5.6 7.7 3.2 8.5L3.2 18.4C5.6 17.6 8.8 17.8 11.3 19.3Z" fill="currentColor"/>
        <path d="M12.7 9.4C15.2 7.9 18.4 7.7 20.8 8.5L20.8 18.4C18.4 17.6 15.2 17.8 12.7 19.3Z" fill="currentColor"/>
      </svg>
      <span>{brand}<small>{brandSub}</small></span>
    </span>
    <div class="controls">
      {filters.map((f, i) => (
        <button class:list={['filterbtn', { active: i === 0 }]} data-filter={f.value}>{f.label}</button>
      ))}
    </div>
  </div>
</div>
