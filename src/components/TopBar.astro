---
interface Filter {
  value: string;
  label: string;
}

interface Props {
  subject?: string;
  brand?: string;
  brandSub?: string;
  filters?: Filter[];
}

const {
  subject = 'biologi',
  brand = 'Biologi X',
  brandSub = 'Catatan Lapangan',
  filters = [
    { value: 'all', label: 'Semua' },
    { value: 'jamur', label: 'Jamur' },
    { value: 'eko', label: 'Ekosistem' },
  ],
} = Astro.props;
---

<div class="topbar" id="topbar">
  <div class="wrap">
    <span class="brand">
      {subject === 'biologi' ? (
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4C7.6 4 4 6.8 4 10c0 .9.7 1.5 1.6 1.5h12.8c.9 0 1.6-.6 1.6-1.5 0-3.2-3.6-6-8-6z" fill="#e0533d"/><path d="M9.6 11.5h4.8l-.5 6.6a1.9 1.9 0 0 1-3.8 0z" fill="#1a1a1a"/></svg>
      ) : (
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5.5C3 4.7 3.7 4 4.5 4H11v15H4.5c-.8 0-1.5-.7-1.5-1.5z" fill="#e0533d"/><path d="M21 5.5C21 4.7 20.3 4 19.5 4H13v15h6.5c.8 0 1.5-.7 1.5-1.5z" fill="#1a1a1a"/></svg>
      )}
      <span>{brand}<small>{brandSub}</small></span>
    </span>
    <div class="controls">
      {filters.map((f, i) => (
        <button class:list={['filterbtn', { active: i === 0 }]} data-filter={f.value}>{f.label}</button>
      ))}
      <span class="searchwrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3" stroke-linecap="round"/></svg>
        <input id="search" type="search" placeholder="cari materi..." aria-label="Cari materi">
      </span>
    </div>
  </div>
</div>
